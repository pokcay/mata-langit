# Copy to .env on the Hostinger VPS (or paste into Docker Manager env UI).
# Required:
RAILS_MASTER_KEY=your_master_key_from_config_master_key

# Database password (must match POSTGRES_PASSWORD in docker-compose.yml)
DATABASE_PASSWORD=postgres

# Public host for mailer links / sitemap — set to your VPS IP or Hostinger hostname when known.
APP_HOST=localhost

# Host header allowlist. Use * until you have a domain, then e.g. 203.0.113.5,yourdomain.com
RAILS_ALLOWED_HOSTS=*

# Set true after HTTPS + domain are configured behind a reverse proxy.
FORCE_SSL=false
ASSUME_SSL=false

# Exposed port on the VPS (Hostinger may map this differently in the panel)
WEB_PORT=3000

# Optional — transactional email (Resend)
# RESEND_API_KEY=re_xxx
# MAIL_FROM=App <noreply@notification.example.com>
# MAIL_REPLY_TO=hello@example.com
