#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

def check_command(cmd)
  system(cmd, out: File::NULL, err: File::NULL)
end

def windows?
  Gem.win_platform?
end

def find_pg_bin_windows
  Dir.glob("C:/Program Files/PostgreSQL/*/bin").max_by do |path|
    path.match(/(\d+)/)[1].to_i rescue 0
  end
end

def add_to_user_path(dir)
  current = `powershell -Command "[Environment]::GetEnvironmentVariable('PATH', 'User')"`.strip
  return if current.downcase.include?(dir.downcase)
  new_path = "#{dir};#{current}"
  system("powershell -Command \"[Environment]::SetEnvironmentVariable('PATH', '#{new_path}', 'User')\"",
         out: File::NULL, err: File::NULL)
end

def ensure_pg_service_running_windows
  svc_name = `powershell -Command "Get-Service -Name 'postgresql*' -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Name -First 1"`.strip rescue ""
  return if svc_name.empty?

  status = `powershell -Command "(Get-Service -Name '#{svc_name}').Status"`.strip rescue ""
  if status == "Running"
    puts "  PostgreSQL service (#{svc_name}) is running ✓"
    return
  end

  puts "  PostgreSQL service (#{svc_name}) is not running. Starting..."
  started = system("net start #{svc_name}", out: File::NULL, err: File::NULL)
  if started
    sleep 2
    puts "  PostgreSQL service started ✓"
  else
    puts "  Could not start PostgreSQL service automatically (may need Administrator)."
    puts "  Fix: Right-click PowerShell → 'Run as Administrator', then run this script again."
    puts "  Or manually: Start → search 'Services' → find PostgreSQL → right-click → Start"
    abort
  end
end

def load_env_file
  return unless File.exist?(".env")
  File.foreach(".env") do |line|
    next if line.strip.empty? || line.start_with?("#")
    if line =~ /\A([A-Z_][A-Z0-9_]*)\s*=\s*(.*)\z/i
      ENV[$1] = $2.strip
    end
  end
end

def ensure_env_file
  if File.exist?(".env")
    load_env_file
    puts "  Using existing .env ✓"
    return
  end
  return unless File.exist?(".env.example")

  puts "  Creating .env from .env.example with default values..."
  content = File.read(".env.example")
  content = content.sub(/^DATABASE_USER=.*/,     "DATABASE_USER=postgres")
  content = content.sub(/^DATABASE_PASSWORD=.*/, "DATABASE_PASSWORD=")
  content = content.sub(/^DATABASE_HOST=.*/,     "DATABASE_HOST=127.0.0.1")
  content = content.sub(/^DATABASE_PORT=.*/,     "DATABASE_PORT=5432")
  File.write(".env", content)
  puts "  Created .env ✓"
  load_env_file
end

def test_pg_connection
  user = ENV["DATABASE_USER"] || ENV["USERNAME"] || ENV["USER"]
  host = ENV["DATABASE_HOST"] || "127.0.0.1"
  port = ENV["DATABASE_PORT"] || "5432"
  ENV["PGPASSWORD"] = ENV["DATABASE_PASSWORD"] || ""
  result = `psql -U "#{user}" -h "#{host}" -p "#{port}" -d postgres -c "SELECT 1" 2>&1`
  $?.success? ? [true, result] : [false, result]
end

def run_reset_postgres_auth_windows
  return false unless File.exist?("bin/reset-postgres-auth.ps1")
  puts ""
  puts "  Attempting to enable passwordless local mode for PostgreSQL..."
  puts "  Windows will ask for Administrator permission (UAC prompt)."
  puts "  Click 'Yes' to allow the configuration update."
  puts ""

  cmd = 'Start-Process powershell -Verb RunAs -Wait -ArgumentList ' \
        '\'-NoProfile\', \'-ExecutionPolicy\', \'Bypass\', \'-File\', ' \
        '\'bin\\reset-postgres-auth.ps1\''
  system("powershell -NoProfile -Command \"#{cmd}\"", out: File::NULL, err: File::NULL)
end

FileUtils.chdir APP_ROOT do
  # This script is a way to set up or update your development environment automatically.
  # This script is idempotent, so that you can run it at any time and get an expectable outcome.
  # Add necessary setup steps to this file.

  puts "== Checking prerequisites =="

  # Check Ruby version
  required_ruby = File.read(".ruby-version").strip rescue nil
  if required_ruby
    current_ruby = RUBY_VERSION
    req_parts = required_ruby.split(".").map(&:to_i)
    cur_parts = current_ruby.split(".").map(&:to_i)
    compatible = cur_parts[0] == req_parts[0] && cur_parts[1] == req_parts[1] && cur_parts[2] >= req_parts[2]
    if compatible
      puts "  Ruby #{current_ruby} ✓"
    else
      puts "  WARNING: Ruby #{required_ruby} is required, but you have #{current_ruby}."
      puts "  Download from: https://rubyinstaller.org/ (Windows) or https://rvm.io (Linux/Mac)"
    end
  end

  # Check Node.js
  if check_command("node --version")
    node_version = `node --version`.strip rescue "unknown"
    puts "  Node.js #{node_version} ✓"
  else
    abort "  ERROR: Node.js not found. Install from https://nodejs.org (>=22.12.0)"
  end

  # Check PostgreSQL — auto-detect and add to PATH on Windows if needed
  unless check_command("psql --version")
    if windows?
      pg_bin = find_pg_bin_windows
      if pg_bin
        puts "  PostgreSQL found at #{pg_bin}, adding to PATH..."
        ENV["PATH"] = "#{pg_bin};#{ENV["PATH"]}"
        add_to_user_path(pg_bin)
        puts "  PATH updated. Future terminals will also have PostgreSQL available."
      else
        abort "  ERROR: PostgreSQL not found.\n" \
              "  Install from: https://www.enterprisedb.com/downloads/postgres-postgresql-downloads"
      end
    else
      abort "  ERROR: PostgreSQL not found. Install PostgreSQL 10+ and make sure it is running."
    end
  end

  ensure_pg_service_running_windows if windows?

  pg_version = `psql --version`.strip rescue "unknown"
  puts "  PostgreSQL (#{pg_version}) ✓"

  puts "\n== Configuring .env =="
  ensure_env_file

  puts "\n== Testing PostgreSQL connection =="
  ok, msg = test_pg_connection
  if !ok && windows?
    puts "  Connection failed with current credentials."
    run_reset_postgres_auth_windows
    puts "  Retrying connection..."
    sleep 1
    ok, msg = test_pg_connection
  end

  if ok
    puts "  Connection OK ✓"
  else
    puts "  ERROR: Could not connect to PostgreSQL:"
    puts msg.lines.map { |l| "    #{l}" }.join
    puts ""
    puts "  Common fixes:"
    puts "    - Edit .env and set the correct DATABASE_PASSWORD"
    puts "    - Try DATABASE_HOST=127.0.0.1 (instead of localhost)"
    puts "    - Make sure the PostgreSQL service is running"
    if windows?
      puts "    - Run .\\bin\\reset-postgres-auth.ps1 manually (right-click → Run as Admin)"
    end
    abort
  end

  rails = windows? ? "ruby bin/rails" : "bin/rails"

  puts "\n== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Preparing database =="
  # On Windows the pg gem reports "server closed the connection unexpectedly"
  # when the target database does not exist yet (instead of "database does not exist").
  # db:create connects via postgres first; db:prepare then migrates safely.
  system! "#{rails} db:create" if windows?
  system! "#{rails} db:prepare"

  puts "\n== Removing old logs and tempfiles =="
  system! "#{rails} log:clear tmp:clear"

  puts "\n== Done =="
  puts "Next steps:"
  puts "  npm install"
  if windows?
    puts "  .\\bin\\dev.ps1    # PowerShell"
  else
    puts "  bin/dev"
  end
end
