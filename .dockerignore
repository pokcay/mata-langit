README.md
CHANGELOG.md
CLAUDE.md
docs
.cursor
.github
tmp/screenshots

# Windows-only scripts (not needed in Linux container)
bin/*.ps1
bin/reset-postgres-auth.ps1

# Cloudflare worker (deploy separately)
cloudflare-worker/node_modules

# Test
test
coverage
