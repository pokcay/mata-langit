# Git
.git
.gitignore
.gitattributes

# Dependencies (rebuilt in image)
node_modules
vendor/bundle

# Local env and secrets
.env
.env.*
!.env.example
!.env.docker.example

# Logs, temp, storage
log/*
tmp/*
storage/*
!log/.keep
